<?xml version="1.0" encoding="UTF-8"?>
<!--
  INSTRUÇÕES:
  Abra o arquivo ios/App/App/Info.plist no Xcode (ou em qualquer editor de texto)
  e adicione as linhas abaixo DENTRO da tag <dict> principal, antes do </dict> final.
  
  Essas chaves são obrigatórias para que o @capacitor/camera funcione no iOS.
  Sem elas o app trava silenciosamente ao tentar acessar fotos/câmera.
-->

<!-- Câmera -->
<key>NSCameraUsageDescription</key>
<string>Para fotografar e gravar memórias diretamente no app</string>

<!-- Leitura da galeria (iOS 14 e anterior) -->
<key>NSPhotoLibraryUsageDescription</key>
<string>Para importar suas fotos e vídeos e fazer backup automático</string>

<!-- Salvar na galeria (caso queira exportar de volta) -->
<key>NSPhotoLibraryAddUsageDescription</key>
<string>Para salvar memórias exportadas na sua galeria</string>

<!--
  IMPORTANTE — iOS 14+:
  O PHPickerViewController (usado pelo Camera.pickImages) NÃO exige
  NSPhotoLibraryUsageDescription para funcionar. Mas mantê-la garante
  compatibilidade com iOS 13 e evita rejeição na revisão da App Store.
-->